{
  "buildCommand": "npm run vercel-build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "framework": "other",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "FIREBASE_API_KEY": "@firebase_api_key",
    "FIREBASE_AUTH_DOMAIN": "@firebase_auth_domain",
    "FIREBASE_PROJECT_ID": "@firebase_project_id",
    "FIREBASE_STORAGE_BUCKET": "@firebase_storage_bucket",
    "FIREBASE_MESSAGING_SENDER_ID": "@firebase_messaging_sender_id",
    "FIREBASE_APP_ID": "@firebase_app_id",
    "FIREBASE_MEASUREMENT_ID": "@firebase_measurement_id",
    "ENCRYPTION_BASE_KEY": "@encryption_base_key",
    "ENCRYPTION_SALT": "@encryption_salt",
    "ENCRYPTION_ITERATIONS": "100000",
    "ENCRYPTION_KEY_SIZE": "512",
    "ADMIN_USERNAME": "Ahmed",
    "ADMIN_PASSWORD": "@admin_password",
    "ADMIN_EMAIL": "tech7infopro@gmail.com",
    "SUPPORT_EMAIL": "tech7infopro@gmail.com",
    "TELEGRAM_LINK": "https://t.me/+IvjWx9QcwyQxYmI8",
    "WEBSITE_URL": "https://ahmedtech.dz",
    "APP_NAME": "AHMEDTECH DZ-IPTV",
    "APP_VERSION": "1.2.2",
    "RELEASE_DATE": "2025-12-19",
    "MAX_LOGIN_ATTEMPTS": "5",
    "SESSION_TIMEOUT": "30",
    "PASSWORD_MIN_LENGTH": "8"
  }
}
